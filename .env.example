# FlowPay — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# ── Google Gemini ──────────────────────────────────────────────────────────────
# Used by: lib/parser.ts
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_ai_api_key_here

# ── ENS Resolution ────────────────────────────────────────────────────────────
# Used by: lib/resolver.ts — Ethereum mainnet RPC for ENS lookups
# Optional: defaults to Cloudflare's public endpoint (https://cloudflare-eth.com)
# For production use Alchemy/Infura to avoid rate limits
ETHEREUM_RPC_URL=https://cloudflare-eth.com

# ── LI.FI Composer SDK ────────────────────────────────────────────────────────
# Used by: lib/lifi.ts
# Get your key at: https://portal.li.fi
LIFI_API_KEY=your_lifi_api_key_here

# ── Hedera Testnet ────────────────────────────────────────────────────────────
# Used by: lib/hedera.ts
# Create a free testnet account at: https://portal.hedera.com
#
# Operator account — pays transaction fees (ECDSA key pair)
HEDERA_ACCOUNT_ID=0.0.YOUR_ACCOUNT_ID
HEDERA_PRIVATE_KEY=0x_YOUR_ECDSA_PRIVATE_KEY

# Default HBAR recipient for demo (Hedera treasury is safe for testnet)
HEDERA_RECIPIENT_ID=0.0.98

# HCS audit trail topic — leave blank on first run, auto-created
HEDERA_TOPIC_ID=
